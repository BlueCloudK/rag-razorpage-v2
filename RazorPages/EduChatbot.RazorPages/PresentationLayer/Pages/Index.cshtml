@page
@model EduChatbot.RazorPages.Pages.IndexModel
@using ServiceLayer.Services
@{
    Layout = null;
    var subjects = Model.Subjects?.ToList() ?? new List<ServiceLayer.Models.SubjectDto>();
    var dashboard = Model.Dashboard;
    var organization = dashboard?.Organization;
    var plan = Model.Subscription;
    var totalDocs = subjects.Sum(s => s.Documents?.Count ?? 0);
    var indexedDocs = subjects.Sum(s => s.Documents?.Count(d => d.IsIndexed) ?? 0);
    var processingDocs = dashboard?.ProcessingDocumentCount ?? 0;
    var planIsUnlimited = plan?.IsUnlimited == true;
    var questionUsage = plan == null ? "-" : planIsUnlimited ? "Unlimited" : $"{plan.QuestionsUsedToday}/{plan.MaxQuestionsPerDay}";
    var documentUsage = plan == null ? "-" : planIsUnlimited ? "Unlimited" : $"{plan.DocumentsUsed}/{plan.MaxDocuments}";
    var subjectUsage = plan == null ? "-" : planIsUnlimited ? "Unlimited" : $"{plan.SubjectsUsed}/{plan.MaxSubjects}";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(organization?.Name ?? "EduChatbot") - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; background: #101012; color: #eef1f7; font-family: "Inter", sans-serif; }
        a { color: inherit; text-decoration: none; }
        .topbar { height: 64px; padding: 0 28px; border-bottom: 1px solid #25252b; display: flex; align-items: center; justify-content: space-between; background: #121214; position: sticky; top: 0; z-index: 10; }
        .brand { color: #f8f9fc; display: inline-flex; align-items: center; gap: 10px; font-weight: 800; font-size: 1.05rem; }
        .brand-icon { width: 34px; height: 34px; display: grid; place-items: center; border-radius: 9px; color: #fff; background: linear-gradient(135deg, #6875f5, #8755b9); }
        .top-actions, .header-actions, .course-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
        .account { display: inline-flex; align-items: center; gap: 8px; color: #c6ccda; font-size: .8rem; border: 1px solid #303038; border-radius: 999px; padding: 8px 11px; background: #19191d; }
        .account strong { color: #f0f3f8; }
        .role { color: #9ba6ff; font-weight: 800; }
        .btn-ui { min-height: 36px; border: 1px solid #303038; border-radius: 8px; background: #19191d; color: #d7dce7; padding: 8px 11px; display: inline-flex; align-items: center; gap: 7px; font-size: .78rem; font-weight: 800; cursor: pointer; }
        .btn-ui:hover { color: #fff; border-color: #6675ee; background: rgba(102,117,238,.12); }
        .btn-ui.primary { color: #fff; border-color: #6070e8; background: #5262d6; }
        .btn-ui.danger { color: #ff96a2; border-color: #4a2b31; background: #24191c; }
        .btn-icon { width: 34px; height: 34px; justify-content: center; padding: 0; }
        .shell { max-width: 1360px; margin: 0 auto; padding: 34px 28px 56px; }
        .workspace-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; margin-bottom: 24px; }
        .eyebrow { margin-bottom: 7px; color: #9ba6ff; font-size: .69rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
        h1 { margin: 0; color: #f7f9fd; font-size: 1.85rem; line-height: 1.2; font-weight: 800; letter-spacing: 0; }
        .subtitle { margin: 8px 0 0; max-width: 720px; color: #9fa7b7; font-size: .9rem; line-height: 1.55; }
        .dashboard-layout { display: grid; grid-template-columns: minmax(0, 1fr) 310px; gap: 20px; align-items: start; }
        .main-column { min-width: 0; }
        .metric-row { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); border: 1px solid #28282f; border-radius: 10px; background: #18181c; margin-bottom: 24px; overflow: hidden; }
        .metric { min-height: 88px; padding: 15px 17px; border-right: 1px solid #28282f; }
        .metric:last-child { border-right: 0; }
        .metric-icon { color: #7e8cff; font-size: .95rem; }
        .metric-value { margin-top: 8px; color: #f6f8fc; font-size: 1.28rem; font-weight: 800; }
        .metric-label { margin-top: 2px; color: #929aaa; font-size: .72rem; }
        .panel { border: 1px solid #28282f; border-radius: 10px; background: #18181c; }
        .section-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 13px; }
        .section-title { color: #e8ebf2; font-size: .98rem; font-weight: 800; display: inline-flex; align-items: center; gap: 8px; }
        .section-title i { color: #7e8cff; }
        .section-note { color: #929aaa; font-size: .78rem; }
        .course-list { overflow: hidden; }
        .course-row { min-height: 102px; padding: 17px 18px; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 16px; align-items: center; border-bottom: 1px solid #28282f; }
        .course-row:last-child { border-bottom: 0; }
        .course-row:hover { background: #1b1b20; }
        .course-main { min-width: 0; display: flex; align-items: center; gap: 14px; }
        .course-icon { width: 42px; height: 42px; flex: 0 0 42px; display: grid; place-items: center; border: 1px solid #39416c; border-radius: 9px; color: #8994ff; background: #20233a; }
        .course-name { color: #f5f7fb; font-size: .95rem; font-weight: 800; }
        .course-meta { margin-top: 6px; color: #9da5b5; display: flex; gap: 13px; flex-wrap: wrap; font-size: .73rem; }
        .course-meta span { display: inline-flex; align-items: center; gap: 5px; }
        .course-health { color: #80d6a0; }
        .empty { padding: 34px 20px; color: #929aaa; text-align: center; font-size: .85rem; }
        .side-stack { display: grid; gap: 14px; }
        .side-panel { padding: 17px; }
        .plan-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
        .plan-name { color: #f8f9fd; font-size: 1.22rem; font-weight: 800; }
        .plan-badge { color: #80d6a0; border: 1px solid #29533b; border-radius: 999px; background: #193123; padding: 4px 7px; font-size: .65rem; font-weight: 800; }
        .plan-detail { margin: 8px 0 14px; color: #9ca5b5; font-size: .76rem; line-height: 1.55; }
        .usage-list { display: grid; gap: 10px; }
        .usage-item { display: grid; gap: 5px; }
        .usage-line { display: flex; justify-content: space-between; gap: 10px; color: #c8ced9; font-size: .73rem; }
        .usage-line strong { color: #f3f5fa; }
        .usage-track { height: 5px; overflow: hidden; border-radius: 999px; background: #292930; }
        .usage-fill { display: block; height: 100%; border-radius: inherit; background: #6675ee; }
        .plan-footer { margin-top: 15px; padding-top: 13px; border-top: 1px solid #292930; display: grid; gap: 8px; }
        .admin-note { color: #d8bd75; font-size: .7rem; line-height: 1.45; }
        .status-list { display: grid; gap: 10px; }
        .status-line { display: flex; align-items: center; justify-content: space-between; gap: 10px; color: #a9b0bf; font-size: .75rem; }
        .status-line strong { color: #f0f2f7; }
        .modal-content { color: #edf0f5; border: 1px solid #303038; border-radius: 10px; background: #1a1a1e; }
        .modal-header, .modal-footer { border-color: #303038; }
        .dark-input { color: #eef1f7; border: 1px solid #303038; border-radius: 8px; background: #101012; padding: 11px 12px; }
        .dark-input:focus { color: #fff; border-color: #6675ee; background: #101012; box-shadow: 0 0 0 3px rgba(102,117,238,.12); }
        .dark-input::placeholder { color: #697181; }
        .form-label { color: #c5cbd6; font-weight: 700; }
        .realtime-toast { position: fixed; right: 18px; bottom: 18px; z-index: 30; max-width: 340px; border: 1px solid #2c3d61; border-radius: 10px; background: #171b28; color: #e8ebf4; box-shadow: 0 18px 55px rgba(0,0,0,.38); padding: 12px 14px; display: none; align-items: flex-start; gap: 10px; font-size: .78rem; line-height: 1.45; }
        .realtime-toast.show { display: flex; }
        .realtime-toast i { color: #85d59d; margin-top: 1px; }
        @@media (max-width: 980px) {
            .dashboard-layout { grid-template-columns: 1fr; }
            .side-stack { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }
        @@media (max-width: 720px) {
            .topbar { height: auto; padding: 12px 16px; align-items: flex-start; gap: 12px; flex-direction: column; }
            .top-actions { width: 100%; }
            .shell { padding: 25px 16px 40px; }
            .workspace-header { flex-direction: column; }
            .metric-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .metric:nth-child(2) { border-right: 0; }
            .metric:nth-child(-n+2) { border-bottom: 1px solid #28282f; }
            .course-row { grid-template-columns: 1fr; }
            .course-actions { padding-left: 56px; }
            .side-stack { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
<header class="topbar">
    <a class="brand" asp-page="/Index">
        <span class="brand-icon"><i class="bi bi-mortarboard-fill"></i></span>
        EduChatbot
    </a>
    <div class="top-actions">
        <span class="account"><i class="bi bi-person-circle"></i><strong>@Model.DisplayName</strong><span class="role">@Model.PrimaryRole</span></span>
        @if (Model.IsAdmin)
        {
            <a class="btn-ui" asp-page="/Admin/Users"><i class="bi bi-sliders"></i> Admin</a>
            <a class="btn-ui" asp-page="/Admin/Activity"><i class="bi bi-activity"></i> Logs</a>
        }
        <form method="post" asp-page="/Account/Logout" class="m-0">
            <button class="btn-ui danger" type="submit"><i class="bi bi-box-arrow-right"></i> Logout</button>
        </form>
    </div>
</header>

<main class="shell">
    <section class="workspace-header">
        <div>
            <div class="eyebrow">Organization workspace</div>
            <h1>@(organization?.Name ?? "EduChatbot Workspace")</h1>
            <p class="subtitle">Manage subjects, indexed documents, access control, and RAG learning activity inside one academic workspace.</p>
        </div>
        <div class="header-actions">
            @if (Model.CanCreateSubject)
            {
                <button class="btn-ui primary" type="button" data-bs-toggle="modal" data-bs-target="#createModal"><i class="bi bi-plus-lg"></i> Create subject</button>
            }
        </div>
    </section>

    <div class="dashboard-layout">
        <div class="main-column">
            <section class="metric-row" aria-label="Workspace overview">
                <div class="metric">
                    <i class="bi bi-journal-bookmark metric-icon"></i>
                    <div class="metric-value">@subjects.Count</div>
                    <div class="metric-label">Accessible subjects</div>
                </div>
                <div class="metric">
                    <i class="bi bi-database-check metric-icon"></i>
                    <div class="metric-value">@indexedDocs/@totalDocs</div>
                    <div class="metric-label">Indexed documents</div>
                </div>
                <div class="metric">
                    <i class="bi bi-people metric-icon"></i>
                    <div class="metric-value">@(dashboard?.MemberCount ?? 0)</div>
                    <div class="metric-label">Workspace members</div>
                </div>
                <div class="metric">
                    <i class="bi bi-chat-dots metric-icon"></i>
                    <div class="metric-value">@(plan?.QuestionsUsedToday ?? 0)</div>
                    <div class="metric-label">Organization questions today</div>
                </div>
            </section>

            <section>
                <div class="section-head">
                    <div>
                        <div class="section-title"><i class="bi bi-book"></i> Subjects</div>
                        <div class="section-note mt-1">Open a subject to chat, inspect indexed chunks, or manage members if your role allows it.</div>
                    </div>
                    <span class="section-note">@subjects.Count subjects</span>
                </div>

                <div class="panel course-list">
                    @foreach (var subject in subjects.OrderBy(s => s.Name))
                    {
                        var docs = subject.Documents?.Count() ?? 0;
                        var readyDocs = subject.Documents?.Count(d => d.IsIndexed) ?? 0;
                        var usage = Model.SubjectUsage.TryGetValue(subject.Id, out var item) ? item : null;
                        <article class="course-row" data-subject-card="@subject.Id">
                            <a class="course-main" asp-page="/Chat/Index" asp-route-subjectId="@subject.Id" asp-route-tab="chat">
                                <span class="course-icon"><i class="bi bi-book"></i></span>
                                <span>
                                    <span class="course-name">@subject.Name</span>
                                    <span class="course-meta">
                                        <span><i class="bi bi-tag"></i> @subject.Code</span>
                                        <span><i class="bi bi-file-earmark-text"></i> @docs documents</span>
                                        <span class="course-health"><i class="bi bi-check-circle"></i> @readyDocs indexed</span>
                                        @if (Model.IsAdmin || Model.IsLecturer)
                                        {
                                            <span><i class="bi bi-chat-left-text"></i> @(usage?.QuestionCount ?? 0) questions</span>
                                            <span><i class="bi bi-layers"></i> @(usage?.SessionCount ?? 0) sessions</span>
                                        }
                                    </span>
                                </span>
                            </a>
                            <div class="course-actions">
                                <a class="btn-ui" asp-page="/Chat/Index" asp-route-subjectId="@subject.Id"><i class="bi bi-chat-dots"></i> Chat</a>
                                @if (Model.IsAdmin || subject.CurrentUserRole == AuthConstants.SubjectLead)
                                {
                                    <a class="btn-ui btn-icon" asp-page="/Chat/Index" asp-route-subjectId="@subject.Id" asp-route-tab="members" title="Members" aria-label="Members"><i class="bi bi-people"></i></a>
                                    <a class="btn-ui btn-icon" asp-page="/Chat/Index" asp-route-subjectId="@subject.Id" asp-route-tab="settings" title="Settings" aria-label="Settings"><i class="bi bi-gear"></i></a>
                                }
                            </div>
                        </article>
                    }
                    @if (!subjects.Any())
                    {
                        <div class="empty">No subjects are available for your account yet.</div>
                    }
                </div>
            </section>
        </div>

        <aside class="side-stack">
            <section class="panel side-panel">
                <div class="eyebrow">Organization plan</div>
                <div class="plan-head">
                    <div class="plan-name">@(plan?.PlanName ?? "Free")</div>
                    <span class="plan-badge">@(Model.IsAdmin ? "Admin view" : "Active")</span>
                </div>
                <p class="plan-detail">Gemini: @(plan?.AllowGemini == true || planIsUnlimited ? "Enabled" : "Disabled") - Max file: @(planIsUnlimited ? "Unlimited" : $"{plan?.MaxFileSizeMb ?? 0} MB")</p>
                <div class="usage-list">
                    @if (Model.IsAdmin)
                    {
                        <div class="usage-item">
                            <div class="usage-line"><span>Questions today</span><strong>@(plan?.QuestionsUsedToday ?? 0)</strong></div>
                        </div>
                        <div class="usage-item">
                            <div class="usage-line"><span>Documents in organization</span><strong>@(plan?.DocumentsUsed ?? 0)</strong></div>
                        </div>
                        <div class="usage-item">
                            <div class="usage-line"><span>Subjects in organization</span><strong>@(plan?.SubjectsUsed ?? 0)</strong></div>
                        </div>
                    }
                    else
                    {
                        <div class="usage-item">
                            <div class="usage-line"><span>Questions today</span><strong>@questionUsage</strong></div>
                            <span class="usage-track"><span class="usage-fill" style="width:@(planIsUnlimited || plan?.MaxQuestionsPerDay <= 0 ? 100 : Math.Min(100, plan!.QuestionsUsedToday * 100 / plan.MaxQuestionsPerDay))%"></span></span>
                        </div>
                        <div class="usage-item">
                            <div class="usage-line"><span>Documents</span><strong>@documentUsage</strong></div>
                            <span class="usage-track"><span class="usage-fill" style="width:@(planIsUnlimited || plan?.MaxDocuments <= 0 ? 100 : Math.Min(100, plan!.DocumentsUsed * 100 / plan.MaxDocuments))%"></span></span>
                        </div>
                        <div class="usage-item">
                            <div class="usage-line"><span>Subjects</span><strong>@subjectUsage</strong></div>
                            <span class="usage-track"><span class="usage-fill" style="width:@(planIsUnlimited || plan?.MaxSubjects <= 0 ? 100 : Math.Min(100, plan!.SubjectsUsed * 100 / plan.MaxSubjects))%"></span></span>
                        </div>
                    }
                </div>
                <div class="plan-footer">
                    @if (Model.IsAdmin)
                    {
                        <div class="admin-note"><i class="bi bi-shield-check me-1"></i>Admin monitors organization usage, but document upload remains a lecturer or subject-lead responsibility.</div>
                        <a class="btn-ui primary" asp-page="/Billing/Index"><i class="bi bi-credit-card"></i> Change plan</a>
                    }
                    else
                    {
                        <div class="section-note">Quota belongs to the organization plan, not to a separate personal subscription.</div>
                    }
                </div>
            </section>

            @if (Model.IsAdmin || Model.IsLecturer)
            {
                <section class="panel side-panel">
                    <div class="eyebrow">System status</div>
                    <div class="status-list">
                        <div class="status-line"><span><i class="bi bi-database-check me-2"></i>Ready documents</span><strong>@indexedDocs</strong></div>
                        <div class="status-line"><span><i class="bi bi-arrow-repeat me-2"></i>Processing</span><strong>@processingDocs</strong></div>
                        <div class="status-line"><span><i class="bi bi-people me-2"></i>Members</span><strong>@(dashboard?.MemberCount ?? 0)</strong></div>
                    </div>
                </section>
            }
        </aside>
    </div>
</main>

@if (Model.CanCreateSubject)
{
    <div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <form method="post" asp-page-handler="Create" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="createModalTitle"><i class="bi bi-plus-circle me-2 text-primary"></i>Create subject</h5>
                    <button class="btn-close btn-close-white" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label small" asp-for="Input.Name">Subject name</label>
                        <input class="form-control dark-input" asp-for="Input.Name" required placeholder="Example: Software Testing" autocomplete="off" />
                    </div>
                    <div>
                        <label class="form-label small" asp-for="Input.Code">Subject code</label>
                        <input class="form-control dark-input" asp-for="Input.Code" required placeholder="Example: SWT301" autocomplete="off" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn-ui" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn-ui primary" type="submit">Create subject</button>
                </div>
            </form>
        </div>
    </div>
}

<div class="realtime-toast" id="realtimeToast" role="status" aria-live="polite">
    <i class="bi bi-broadcast-pin"></i>
    <span id="realtimeToastText">Workspace updated.</span>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    (function () {
        if (!window.signalR) return;

        const currentUserId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CurrentUserId));
        const currentUserIsAdmin = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IsAdmin));
        const toast = document.getElementById('realtimeToast');
        const toastText = document.getElementById('realtimeToastText');
        let toastTimer = null;
        let refreshTimer = null;

        function showRealtimeToast(message) {
            if (!toast || !toastText) return;
            toastText.textContent = message;
            toast.classList.add('show');
            window.clearTimeout(toastTimer);
            toastTimer = window.setTimeout(() => toast.classList.remove('show'), 2800);
        }

        function scheduleRefresh(message, delay = 900) {
            showRealtimeToast(message);
            window.clearTimeout(refreshTimer);
            refreshTimer = window.setTimeout(() => window.location.reload(), delay);
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/workspace')
            .withAutomaticReconnect()
            .build();

        connection.on('SubjectChanged', event => {
            const action = String(event?.action || '');
            const subjectId = event?.subjectId;
            if (action === 'deleted' && subjectId) {
                document.querySelector(`[data-subject-card="${subjectId}"]`)?.remove();
                scheduleRefresh(`${event.subjectName || 'A subject'} was deleted. Updating workspace...`);
                return;
            }

            scheduleRefresh(action === 'created'
                ? 'A new subject was created. Updating workspace...'
                : 'A subject was updated. Refreshing dashboard...');
        });

        connection.on('DocumentChanged', event => {
            const name = event?.fileName ? `Document ${event.fileName}` : 'Document';
            scheduleRefresh(`${name} ${event?.action || 'changed'}. Updating counts...`);
        });

        connection.on('MembershipChanged', event => {
            const affectedUserId = String(event?.userId || '');
            const action = String(event?.action || '');
            const subjectId = event?.subjectId;

            if (affectedUserId && affectedUserId !== currentUserId && !currentUserIsAdmin) {
                return;
            }

            if (action === 'removed' && subjectId) {
                document.querySelector(`[data-subject-card="${subjectId}"]`)?.remove();
            }

            const message = action === 'added'
                ? 'You were added to a subject. Updating workspace...'
                : action === 'removed'
                    ? 'Your subject access changed. Updating workspace...'
                    : 'Subject membership changed. Updating access...';
            scheduleRefresh(message);
        });

        connection.on('AdminChanged', () => {
            scheduleRefresh('Admin data changed. Updating dashboard...');
        });

        connection.start().catch(() => {
            // Realtime is a convenience layer; the app still works with normal refresh.
        });
    })();
</script>
</body>
</html>
