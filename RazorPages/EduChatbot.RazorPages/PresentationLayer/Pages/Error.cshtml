@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="admin-page narrow-page">
    <div class="admin-hero">
        <div>
            <p class="eyebrow">System error</p>
            <h1>We could not process this request</h1>
            <p>An application error occurred. Use the request ID below when debugging locally.</p>
        </div>
        <a class="secondary" asp-page="/Index">Back to dashboard</a>
    </div>

    @if (Model.ShowRequestId)
    {
        <section class="admin-panel">
            <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        </section>
    }

    <section class="admin-panel">
        <h2>Development note</h2>
        <p class="muted">Detailed exception pages should only be enabled in local development. Keep production error screens privacy-safe.</p>
    </section>
</section>
