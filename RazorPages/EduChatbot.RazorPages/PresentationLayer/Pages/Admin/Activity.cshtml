@page
@model PresentationLayer.Pages.Admin.ActivityModel
@{
    ViewData["Title"] = "Activity audit";
}

<section class="admin-page">
    <div class="admin-hero">
        <div>
            <p class="eyebrow">Operations</p>
            <h1>Activity audit</h1>
            <p>Privacy-safe logs for login, account changes, subject access, document operations, and chat usage. Question text, AI answers, and document content are not stored here.</p>
        </div>
    </div>

    <section class="admin-panel">
        <div class="panel-title">
            <div>
                <h2>Subject chat usage</h2>
                <p>Lecturers can use this view to understand activity without reading private conversations.</p>
            </div>
            <span class="metric-badge">@Model.Data.SubjectUsage.Sum(s => s.QuestionCount) questions</span>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Subject</th>
                        <th>Questions</th>
                        <th>Sessions</th>
                        <th>Last activity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var subject in Model.Data.SubjectUsage)
                    {
                        <tr>
                            <td><strong>@subject.SubjectName</strong><br /><span class="muted">@subject.SubjectCode</span></td>
                            <td>@subject.QuestionCount</td>
                            <td>@subject.SessionCount</td>
                            <td>@(subject.LastAskedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "No chat yet")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="admin-panel">
        <div class="panel-title">
            <div>
                <h2>Recent operational logs</h2>
                <p>System actions only, with no document body or chat message content.</p>
            </div>
            <span class="metric-badge safe">privacy-safe</span>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Actor</th>
                        <th>Action</th>
                        <th>Target</th>
                        <th>Summary</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Data.RecentLogs)
                    {
                        <tr>
                            <td>@log.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td><strong>@log.ActorEmail</strong><br /><span class="muted">@log.ActorRole</span></td>
                            <td>@log.Action</td>
                            <td>@log.EntityType @(log.EntityId.HasValue ? $"#{log.EntityId}" : "")</td>
                            <td>@log.Summary</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</section>
