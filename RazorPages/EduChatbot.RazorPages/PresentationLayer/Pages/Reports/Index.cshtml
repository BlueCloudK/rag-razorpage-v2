@page
@model PresentationLayer.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Reports";
    var totalTokens = Math.Max(Model.Report.TotalTokens, 1);
    var inputPercent = Math.Round((double)Model.Report.TotalInputTokens / totalTokens * 100, 1);
    var contextPercent = Math.Round((double)Model.Report.TotalRetrievedContextTokens / totalTokens * 100, 1);
    var outputPercent = Math.Round((double)Model.Report.TotalOutputTokens / totalTokens * 100, 1);
    var isTeachingScope = Model.Report.ScopeKind == "teaching";
}

<section class="reports-page">
    <header class="reports-header">
        <div class="reports-heading">
            <div class="reports-title-row">
                <div>
                    <p class="eyebrow">Reports and statistics</p>
                    <h1>@Model.Report.ScopeLabel</h1>
                </div>
                <span class="scope-badge">@(isTeachingScope ? "Lecturer scope" : "Organization scope")</span>
            </div>
            <p>@Model.Report.ScopeDescription Privacy-safe totals only: prompts, answers, and document text are never shown here.</p>
        </div>
        <div class="reports-actions">
            @if (Model.Report.TokensAreEstimated)
            {
                <span class="estimate-badge">Token values are estimated</span>
            }
            <a class="detail-link" asp-page="/Reports/Usage">View detailed usage</a>
        </div>
    </header>

    <div class="kpi-grid" aria-label="Usage summary">
        <article class="kpi-card">
            <span>Total tokens</span>
            <strong>@Model.Report.TotalTokens.ToString("N0")</strong>
            <small>Input, retrieved context, and AI answer tokens</small>
        </article>
        <article class="kpi-card">
            <span>Completed questions</span>
            <strong>@Model.Report.CompletedQuestionCount.ToString("N0")</strong>
            <small>Completed AI answers in the last 30 days</small>
        </article>
        <article class="kpi-card">
            <span>@(isTeachingScope ? "Active learners" : "Active users")</span>
            <strong>@Model.Report.ActiveUserCount.ToString("N0")</strong>
            <small>@(isTeachingScope ? "Learners active across your teaching subjects" : "Users with completed answers in scope")</small>
        </article>
        <article class="kpi-card">
            <span>@(isTeachingScope ? "Teaching subjects" : "Indexed documents")</span>
            <strong>@(isTeachingScope ? Model.Report.AccessibleSubjectCount.ToString("N0") : Model.Report.IndexedDocumentCount.ToString("N0"))</strong>
            <small>@(isTeachingScope ? "Subjects where you are lecturer or subject lead" : "Indexed documents connected to active subjects")</small>
        </article>
    </div>

    @if (!Model.HasUsage)
    {
        <section class="report-empty-panel" role="status">
            <div class="empty-icon" aria-hidden="true">0</div>
            <div>
                <p class="section-kicker">Tracking status</p>
                <h2>No completed AI answers tracked yet</h2>
                <p>Token tracking starts when an AI answer completes successfully in your scope. Historical chat messages are intentionally not backfilled.</p>
            </div>
            <a class="detail-link secondary-action" asp-page="/Subjects/Index">Open subjects</a>
        </section>
    }
    else
    {
    <div class="report-layout">
        <section class="report-panel chart-panel" aria-labelledby="daily-tokens-heading">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Last 30 days</p>
                    <h2 id="daily-tokens-heading">Daily token usage</h2>
                </div>
                <span>@Model.Report.StartDate.ToString("dd MMM") - @Model.Report.EndDate.ToString("dd MMM")</span>
            </div>

            <div class="token-chart" aria-label="Daily token totals">
                @if (Model.Report.DailyUsages.Count == 0)
                {
                    <div class="chart-empty">No completed AI answers in this period.</div>
                }
                else
                {
                    @foreach (var day in Model.Report.DailyUsages)
                    {
                        var height = Math.Max(6, Math.Round((double)day.TotalTokens / Model.MaxDailyTokens * 100));
                        <div class="chart-day">
                            <span class="bar" style="height:@height%" title="@day.Date.ToString("dd MMM yyyy"): @day.TotalTokens.ToString("N0") tokens"></span>
                            <small>@day.Date.ToString("dd/MM")</small>
                        </div>
                    }
                }
            </div>
        </section>

        <section class="report-panel breakdown-panel" aria-labelledby="breakdown-heading">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Token mix</p>
                    <h2 id="breakdown-heading">Token breakdown</h2>
                </div>
            </div>

            <div class="breakdown-list">
                <div class="breakdown-row">
                    <div>
                        <strong>Question input</strong>
                        <span>@inputPercent%</span>
                    </div>
                    <progress value="@Model.Report.TotalInputTokens" max="@totalTokens"></progress>
                    <b>@Model.Report.TotalInputTokens.ToString("N0")</b>
                </div>
                <div class="breakdown-row">
                    <div>
                        <strong>Retrieved context</strong>
                        <span>@contextPercent%</span>
                    </div>
                    <progress value="@Model.Report.TotalRetrievedContextTokens" max="@totalTokens"></progress>
                    <b>@Model.Report.TotalRetrievedContextTokens.ToString("N0")</b>
                </div>
                <div class="breakdown-row">
                    <div>
                        <strong>AI answer</strong>
                        <span>@outputPercent%</span>
                    </div>
                    <progress value="@Model.Report.TotalOutputTokens" max="@totalTokens"></progress>
                    <b>@Model.Report.TotalOutputTokens.ToString("N0")</b>
                </div>
            </div>
        </section>
    </div>
    }
</section>
