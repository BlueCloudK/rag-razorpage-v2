@page
@model EduChatbot.RazorPages.Pages.Billing.IndexModel
@{
    ViewData["Title"] = "Billing";
    var subscription = Model.Portal.Subscription;
    var unlimited = subscription?.IsUnlimited == true;
}

<div class="admin-page">
    <header class="admin-page-head">
        <div>
            <p class="eyebrow">Organization billing</p>
            <h1>Billing</h1>
            <p>Manage the organization plan and mock invoices for @Model.Portal.Organization?.Name.</p>
        </div>
        <div class="admin-actions">
            <a class="secondary" asp-page="/Index">Workspace</a>
            <a class="primary" asp-page="/Billing/Pricing">Change plan</a>
        </div>
    </header>

    <section class="admin-panel mb-4">
        <div class="panel-title">
            <div>
                <h2>Current plan: @(subscription?.PlanName ?? "Free")</h2>
                <p>Quota is shared by the whole organization, not assigned to each individual account.</p>
            </div>
            <span class="metric-badge safe">Active</span>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Questions today</th>
                        <th>Documents</th>
                        <th>Subjects</th>
                        <th>Members</th>
                        <th>Gemini</th>
                        <th>Max file</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@(subscription?.QuestionsUsedToday ?? 0) / @(unlimited ? "Unlimited" : subscription?.MaxQuestionsPerDay)</td>
                        <td>@(subscription?.DocumentsUsed ?? 0) / @(unlimited ? "Unlimited" : subscription?.MaxDocuments)</td>
                        <td>@(subscription?.SubjectsUsed ?? 0) / @(unlimited ? "Unlimited" : subscription?.MaxSubjects)</td>
                        <td>@(subscription?.MembersUsed ?? 0) / @(unlimited ? "Unlimited" : subscription?.MaxMembers)</td>
                        <td>@(subscription?.AllowGemini == true || unlimited ? "Enabled" : "Disabled")</td>
                        <td>@(unlimited ? "Unlimited" : $"{subscription?.MaxFileSizeMb ?? 0} MB")</td>
                    </tr>
                </tbody>
            </table>
        </div>

        @if (Model.Portal.CanManageBilling)
        {
            <form method="post" asp-page-handler="Cancel" class="mt-3" onsubmit="return confirm('Move this organization back to the Free plan?');">
                <button class="danger" type="submit">Cancel to Free</button>
            </form>
        }
    </section>

    <section class="admin-panel">
        <div class="panel-title">
            <div>
                <h2>Invoice history</h2>
                <p>Mock billing records created by demo checkout.</p>
            </div>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Invoice</th>
                        <th>Plan</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Paid at</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in Model.Portal.Invoices)
                    {
                        <tr>
                            <td>@invoice.InvoiceNumber</td>
                            <td>@invoice.PlanName</td>
                            <td>@invoice.Amount.ToString("N0") @invoice.Currency</td>
                            <td><span class="role-chip">@invoice.Status</span></td>
                            <td>@(invoice.PaidAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Portal.Invoices.Any())
                    {
                        <tr><td colspan="5" class="muted">No invoices yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
