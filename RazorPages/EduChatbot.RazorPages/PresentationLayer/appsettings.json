{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AiService": {
    "BaseUrl": "http://127.0.0.1:8000",
    "PythonExecutable": "python",
    "LlmProvider": "ollama",
    "OllamaModel": "gemma3:4b",
    "OllamaFallbackModel": "qwen2.5:3b",
    "OllamaTimeoutSeconds": "120",
    "GeminiModel": "gemini-2.5-flash",
    "LlmTemperature": "0.2",
    "OllamaNumCtx": "4096",
    "OllamaNumPredict": "512",
    "RagCandidatePool": "24",
    "RagRerankTopK": "6",
    "RagMaxContextChars": "5000",
    "RagEnableReranker": "false",
    "RerankerModel": "Qwen/Qwen3-Reranker-0.6B",
    "EmbeddingModel": "Qwen/Qwen3-Embedding-0.6B",
    "EmbeddingDevice": "cuda",
    "EmbeddingBatchSize": "4",
    "ChunkSize": "850",
    "ChunkOverlap": "120",
    "RagEnableAgentic": "true",
    "RagAgenticMaxRounds": "2",
    "RagAgenticMaxSubqueries": "3",
    "RagPlannerMode": "small-llm-with-rule-fallback",
    "RagPlannerModel": "qwen3:1.7b",
    "RagCheckerModel": "qwen3:1.7b",
    "RagAnswerModel": "gemma3:4b",
    "RagPlannerTimeoutSeconds": "45",
    "RagPlannerNumCtx": "2048",
    "RagPlannerNumPredict": "160"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EduChatbotDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  }
}
